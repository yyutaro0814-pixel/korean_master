rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // User profiles
    match /users/{userId} {
      allow read: if true; // Public profiles for now as per "login unnecessary" request
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
